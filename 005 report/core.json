  "problem": {
    "statement": "Hvordan optimalisere lagerbeholdning på tvers av fire hurtigmatutsalgssteder for å minimere sannsynligheten for stockout og minimere totalkostnad (bestilling, lagring og stockout) over en 7-dagersperiode?",
    "decision_variables": ["Bestillingsmengde per produkt per uke per utsalgssted"],
    "objective": "Minimere lagernivå og unngå stockout over en 7-dagersperiode",
    "planning_horizon_days": 7
  },
  "simulation": {
    "source": "Big Ambitions (dataspill)",
    "data_type": "Simulert salgsdata",
