      "MH":        { "first_day": 1, "last_day": 101, "observations": 101 },
      "Warehouse": { "first_day": 1, "last_day": 101, "observations": 101 }
    },
    "notes": [
      "Ingen sesongvariasjoner eller trender",
      "Ingen konkurranse, reklame eller kampanjer",
      "Alle fire utsalgssteder har identisk åpningstidssetting",
      "Innkjøpspris er identisk for alle utsalgssteder",
      "Utsalgspris kan variere mellom steder"
    ]
  },
  "stores": ["GM", "HK", "LM", "MH"],
